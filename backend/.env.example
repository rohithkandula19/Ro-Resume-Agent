# ── LLM providers ───────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here          # optional: for GPT-4 fallback
ANTHROPIC_API_KEY=your_anthropic_key_here    # optional: for Claude fallback

# ── OpenRouter model IDs ─────────────────────────────────────────────────────
OPENROUTER_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FAST_MODEL=google/gemma-2-9b-it:free
OPENROUTER_ALT_MODEL=qwen/qwen-2.5-72b-instruct:free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat:free

# ── Firebase (Auth + Firestore) ───────────────────────────────────────────────
# Option A: paste the entire service account JSON as a single-line env var
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"ro-resume-agent937",...}

# Option B: point to a downloaded service account key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000                 # frontend URL

# ── Email (optional — for notifications) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
